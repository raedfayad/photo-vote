# Copy to .env.local for local dev — add all as GitHub Secrets for CI/CD

# Firebase (Firestore + Storage)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Shared password your friends use to access the voting site
VITE_VOTER_PASSWORD=

# Your Google email — only this account can sign in as admin
VITE_ADMIN_EMAIL=

# Admin login now uses Firebase Authentication (email/password).
# Create the admin user in Firebase console → Authentication → Add user.
# VITE_ADMIN_PASSWORD is no longer used and can be removed from GitHub Secrets.
